  "researchObjectives": {
    "title": "Research Objectives",
    "items": [
      {
        "icon": "Shield",
        "title": "Detect harmful content",
        "description": "Identify cyberbullying in both text and image-based content."
      },
      {
        "icon": "Activity",
        "title": "Detect bot accounts",
        "description": "Analyze user behavior patterns to identify automated or fake accounts."
      },
      {
        "icon": "Heart",
        "title": "Enable emotion-aware interaction",
        "description": "Promote safe and empathetic user engagement based on emotional context."
      },
      {
        "icon": "Eye",
        "title": "Provide explainable recommendations",
        "description": "Deliver transparent friend suggestions with clear reasoning."
      }
    ]
  },
  "methodology": {
    "title": "Methodology",
    "services": [
      {
        "icon": "Shield",
        "title": "Cyberbullying Detection",
        "subtitle": "Multimodal Content Moderation",
        "description": "Detects harmful content in both text and images.",
        "features": [
          "Text classification using transformer models",
          "Image analysis with vision-language models",
          "OCR for extracting text from images",
          "Fusion of text, image, and keyword signals"
        ],
        "extrasTitle": "Output",
        "extras": [
          "Allow",
          "Warn",
          "Delete"
        ]
      },
      {
        "icon": "Activity",
        "title": "Bot Detection",
        "subtitle": "Behavior-Based Analysis",
        "description": "Identifies fake accounts using activity patterns.",
        "features": [
          "Temporal behavior feature extraction",
          "Activity rate and posting patterns",
          "Anomaly detection using hybrid models",
          "Early-stage account analysis"
        ],
        "extrasTitle": "Key Signals",
        "extras": [
          "Posting frequency",
          "Time intervals",
          "Burst activity"
        ]
      },
      {
        "icon": "Heart",
        "title": "Emotion-Aware System",
        "subtitle": "User Interaction Layer",
        "description": "Analyzes emotions to guide user interactions.",
        "features": [
          "Emotion detection from text",
          "Facial emotion recognition from images",
          "Sarcasm and slang detection",
          "Reaction filtering based on emotion"
        ],
        "extrasTitle": "Capabilities",
        "extras": [
          "Emotion classification",
          "Empathetic response suggestions"
        ]
      },
      {
        "icon": "Users",
        "title": "Recommendation System",
        "subtitle": "Explainable Matching",
        "description": "Suggests connections based on shared interests.",
        "features": [
          "Semantic similarity using embeddings",
          "Interest-based user matching",
          "Cosine similarity ranking",
          "Conversation starter suggestions"
        ],
        "extrasTitle": "Explainability",
        "extras": [
          "Shows common interests",
          "Provides reasoning for recommendations"
        ]
      }
    ]
  },
