  "problem": {
    "title": "The Problem",
    "items": [
      "Fragmented content moderation",
      "Cyberbullying in text and images",
      "Fake and bot accounts",
      "Lack of emotion-aware interactions"
    ],
    "summary": "Current social media platforms lack a unified system to ensure safe and meaningful user interactions."
  },
  "solution": {
    "title": "Our Solution",
    "items": [
      "Detects cyberbullying in text and images",
      "Identifies bot accounts using behavior patterns",
      "Enables emotion-aware user interactions",
      "Provides explainable friend recommendations"
    ]
  },
  "domain": {
    "title": "Social Media Intelligence Systems",
    "intro": "Modern social media platforms rely on separate systems for moderation, recommendations, and user interaction, leading to fragmented and inefficient management.",
    "sources": [
      "User-generated content (posts, comments, images)",
      "User behavior and activity logs",
      "Platform recommendation systems",
      "User interaction patterns"
    ],
    "summary": "SensAI addresses this by integrating safety, behavior analysis, emotion awareness, and explainability into a single unified AI system."
  },
  "literatureSurvey": {
    "title": "Literature Survey",
    "body": [
      "Transformer models improve cyberbullying and emotion detection",
      "Multimodal approaches enhance text and image understanding",
      "Behavior-based methods improve bot detection accuracy"
    ],
    "gaps": [
      "Lack of unified systems combining multiple functions",
      "Limited focus on explainability",
      "Weak support for real-time interaction"
    ]
  },
  "literatureReview": {
    "title": "Literature Review",
    "existingSystems": [
      "Focus on single tasks like moderation or recommendation",
      "Struggle with image-based and contextual content",
      "Depend on content-based features for bot detection",
      "Lack transparency in decision-making"
    ],
    "knowledgeGraphSystems": [
      "Improve data representation and relationships",
      "Support better understanding of user interests"
    ],
    "summary": "However, existing systems are fragmented and do not provide a unified, explainable, and real-time solution."
  },
  "researchGap": {
    "title": "Research Gap",
    "items": [
      {
        "icon": "Layers",
        "title": "Lack of Unified Systems",
        "description": "Existing solutions focus on individual tasks like moderation or recommendation, without integration."
      },
      {
        "icon": "Image",
        "title": "Limited Multimodal Detection",
        "description": "Many systems fail to detect harmful content in images and memes alongside text."
      },
      {
        "icon": "EyeOff",
        "title": "Lack of Explainability",
        "description": "Most systems do not provide clear reasoning behind their decisions."
      }
    ]
  },
  "problemSolution": {
